# PSScriptAnalyzer settings for winforge.
# Applied via:  Invoke-ScriptAnalyzer -Path . -Recurse -Settings ./.pslintrc
#
# Only intentional, verified patterns are excluded — not real defects. Any new
# rule violation outside this list still surfaces.
@{
    Severity     = @('Error', 'Warning')

    ExcludeRules = @(
        # Colored, timestamped console output IS the tool's UX (Write-Log /
        # Write-GroupHeader and direct Write-Host in setup.ps1 / tools).
        'PSAvoidUsingWriteHost',

        # Group functions act on collections, so the plural is intentional, and
        # setup.ps1 builds names dynamically as Install-<Group>Programs /
        # Set-<Group>Configuration. Renaming to singular would be wrong and break
        # dispatch.
        'PSUseSingularNouns',

        # Every state change routes through Invoke-SystemConfig, which supports
        # ShouldProcess; -WhatIf is verified end-to-end across all groups. The
        # orchestrators and the always-wrapped registry helpers therefore need no
        # separate ShouldProcess plumbing.
        'PSUseShouldProcessForStateChangingFunctions',

        # winforge targets PowerShell 7 (UTF-8 by default); a BOM is unnecessary
        # and adds churn/tooling friction.
        'PSUseBOMForUnicodeEncodedFile',

        # Write-Log is winforge's own logger; there is no runtime conflict in the
        # tool's own session.
        'PSAvoidOverwritingBuiltInCmdlets'
    )
}
