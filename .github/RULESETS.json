{
  "rulesets": [
    {
      "name": "Main Branch Protection",
      "description": "main is PR-only: no direct pushes, linear history, no force-push or deletion. Solo-friendly (0 required approvals). Required status checks use the real PR job names.",
      "target": "branch",
      "enforcement": "active",
      "bypass_actors": [],
      "conditions": {
        "ref_name": {
          "include": [
            "refs/heads/main"
          ],
          "exclude": []
        }
      },
      "rules": [
        {
          "type": "deletion"
        },
        {
          "type": "non_fast_forward"
        },
        {
          "type": "required_linear_history"
        },
        {
          "type": "pull_request",
          "parameters": {
            "dismiss_stale_reviews_on_push": false,
            "require_code_owner_review": false,
            "require_last_push_approval": false,
            "required_approving_review_count": 0,
            "required_review_thread_resolution": false
          }
        },
        {
          "type": "required_status_checks",
          "parameters": {
            "strict_required_status_checks_policy": false,
            "required_status_checks": [
              { "context": "PSScriptAnalyzer" },
              { "context": "Validate Project Structure" },
              { "context": "Validate Documentation" },
              { "context": "Validate Git History" },
              { "context": "Validate Markdown" },
              { "context": "PowerShell Security Analysis" },
              { "context": "Credential Scanning" }
            ]
          }
        }
      ]
    }
  ]
}
